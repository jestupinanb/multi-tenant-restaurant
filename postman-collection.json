{
  "info": {
    "name": "Multi-Tenant Restaurant API",
    "description": "API collection for the multi-tenant restaurant ordering system. Covers menu item CRUD and order submission endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Menu Items",
      "item": [
        {
          "name": "Create Menu Item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"New Dish\", \"price\": 15.99, \"description\": \"A delicious new addition\"}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/restaurants/{{restaurantId}}/menu-items",
              "host": ["{{baseUrl}}"],
              "path": ["restaurants", "{{restaurantId}}", "menu-items"]
            }
          }
        },
        {
          "name": "List Menu Items",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/restaurants/{{restaurantId}}/menu-items",
              "host": ["{{baseUrl}}"],
              "path": ["restaurants", "{{restaurantId}}", "menu-items"]
            }
          }
        },
        {
          "name": "Get Menu Item",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/restaurants/{{restaurantId}}/menu-items/{{menuItemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["restaurants", "{{restaurantId}}", "menu-items", "{{menuItemId}}"]
            }
          }
        },
        {
          "name": "Update Menu Item",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"price\": 17.99}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/restaurants/{{restaurantId}}/menu-items/{{menuItemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["restaurants", "{{restaurantId}}", "menu-items", "{{menuItemId}}"]
            }
          }
        },
        {
          "name": "Delete Menu Item",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/restaurants/{{restaurantId}}/menu-items/{{menuItemId}}",
              "host": ["{{baseUrl}}"],
              "path": ["restaurants", "{{restaurantId}}", "menu-items", "{{menuItemId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"customerName\": \"John Doe\", \"items\": [{\"menuItemId\": \"bbbbbbbbbbbbbbbbbbbb0001\", \"quantity\": 2}, {\"menuItemId\": \"bbbbbbbbbbbbbbbbbbbb0002\", \"quantity\": 1}]}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/restaurants/{{restaurantId}}/orders",
              "host": ["{{baseUrl}}"],
              "path": ["restaurants", "{{restaurantId}}", "orders"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "restaurantId",
      "value": "aaaaaaaaaaaaaaaaaaaaa001",
      "type": "string"
    },
    {
      "key": "menuItemId",
      "value": "bbbbbbbbbbbbbbbbbbbb0001",
      "type": "string"
    }
  ]
